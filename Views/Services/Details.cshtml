@model foto4.Data.Service

@{
    ViewData["Title"] = "Детайли за услуга";

    string GetCategoryName(object category)
    {
        if (category == null)
        {
            return "Услуга";
        }

        var type = category.GetType();
        var possibleNames = new[] { "Name", "CategoryName", "Title" };

        foreach (var name in possibleNames)
        {
            var property = type.GetProperty(name);
            var value = property?.GetValue(category)?.ToString();

            if (!string.IsNullOrWhiteSpace(value))
            {
                return value;
            }
        }

        return "Услуга";
    }

    var categoryName = GetCategoryName(Model.Categories);
    var durationText = Model.DurationInDays == 0 ? "Веднага" : $"{Model.DurationInDays} дни";
}

<section class="details-hero">
    <div class="container">
        <span class="details-badge">@categoryName</span>
        <h1>@Model.Name</h1>
        <p>@Model.Description</p>
    </div>
</section>

<section class="details-section">
    <div class="container">
        <div class="details-layout">

            <div class="details-main-card">
                <div class="details-icon">📌</div>

                <h2>Описание на услугата</h2>
                <p class="details-description">
                    @Model.Description
                </p>

                <div class="info-grid">
                    <div class="info-box">
                        <span class="info-label">Формат</span>
                        <strong>@Model.Format</strong>
                    </div>

                    <div class="info-box">
                        <span class="info-label">Срок за изпълнение</span>
                        <strong>@durationText</strong>
                    </div>

                    <div class="info-box">
                        <span class="info-label">Категория</span>
                        <strong>@categoryName</strong>
                    </div>

                    <div class="info-box price-box">
                        <span class="info-label">Цена</span>
                        <strong>@Model.Price.ToString("0.00") лв.</strong>
                    </div>
                </div>

                <div class="details-note">
                    <h3>Как да подадете заявка?</h3>
                    <p>
                        Натиснете бутона „Подай заявка“, попълнете вашите данни, добавете нужните параметри
                        и прикачете файл, ако е необходим за изпълнение на услугата.
                    </p>
                </div>
            </div>

            <aside class="details-side-card">
                <h2>Бърза информация</h2>

                <div class="side-row">
                    <span>Услуга</span>
                    <strong>@Model.Name</strong>
                </div>

                <div class="side-row">
                    <span>Формат</span>
                    <strong>@Model.Format</strong>
                </div>

                <div class="side-row">
                    <span>Срок</span>
                    <strong>@durationText</strong>
                </div>

                <div class="side-row total">
                    <span>Цена</span>
                    <strong>@Model.Price.ToString("0.00") лв.</strong>
                </div>

                <div class="details-actions">
                    <a asp-controller="Services"
                       asp-action="SubmitRequest"
                       asp-route-id="@Model.Id"
                       class="btn-request">
                        Подай заявка
                    </a>

                    <a asp-controller="Services"
                       asp-action="Index"
                       class="btn-back">
                        Назад към услугите
                    </a>

                    @if (User.IsInRole("Admin") && Model.Id > 0)
                    {
                        <a asp-action="Edit"
                           asp-route-id="@Model.Id"
                           class="btn-edit">
                            Редактирай
                        </a>
                    }
                </div>
            </aside>

        </div>
    </div>
</section>

<style>
    .details-hero {
        background: linear-gradient(135deg, #111827, #374151);
        color: white;
        padding: 80px 20px;
        text-align: center;
        border-radius: 0 0 35px 35px;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .details-badge {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.14);
        color: #e5e7eb;
        font-weight: 700;
        margin-bottom: 18px;
    }

    .details-hero h1 {
        font-size: 46px;
        font-weight: 800;
        margin-bottom: 15px;
    }

    .details-hero p {
        max-width: 760px;
        margin: 0 auto;
        color: #e5e7eb;
        font-size: 18px;
        line-height: 1.7;
    }

    .details-section {
        background: #f9fafb;
        padding: 60px 20px;
        min-height: 70vh;
    }

    .details-layout {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 28px;
        align-items: start;
    }

    .details-main-card,
    .details-side-card {
        background: white;
        border-radius: 24px;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
    }

    .details-main-card {
        padding: 36px;
    }

    .details-side-card {
        padding: 28px;
        position: sticky;
        top: 20px;
    }

    .details-icon {
        width: 64px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 18px;
        background: #eff6ff;
        font-size: 32px;
        margin-bottom: 20px;
    }

    .details-main-card h2,
    .details-side-card h2 {
        color: #111827;
        margin-bottom: 18px;
        font-weight: 800;
    }

    .details-description {
        color: #4b5563;
        line-height: 1.8;
        font-size: 17px;
        margin-bottom: 28px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 18px;
        margin-bottom: 30px;
    }

    .info-box {
        padding: 20px;
        border-radius: 18px;
        background: #f3f4f6;
        border: 1px solid #e5e7eb;
    }

    .info-label {
        display: block;
        color: #6b7280;
        font-size: 14px;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .info-box strong {
        color: #111827;
        font-size: 18px;
    }

    .price-box {
        background: #ecfdf5;
        border-color: #bbf7d0;
    }

    .price-box strong {
        color: #15803d;
        font-size: 22px;
    }

    .details-note {
        padding: 24px;
        border-radius: 20px;
        background: #fffbeb;
        border: 1px solid #fde68a;
    }

    .details-note h3 {
        color: #92400e;
        margin-bottom: 10px;
        font-weight: 800;
    }

    .details-note p {
        color: #78350f;
        line-height: 1.7;
        margin: 0;
    }

    .side-row {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        padding: 15px 0;
        border-bottom: 1px solid #e5e7eb;
        color: #4b5563;
    }

    .side-row strong {
        color: #111827;
        text-align: right;
    }

    .side-row.total {
        border-bottom: none;
        margin-top: 8px;
        padding: 18px;
        border-radius: 16px;
        background: #ecfdf5;
        color: #166534;
    }

    .side-row.total strong {
        color: #15803d;
        font-size: 22px;
    }

    .details-actions {
        display: grid;
        gap: 12px;
        margin-top: 24px;
    }

    .btn-request,
    .btn-back,
    .btn-edit {
        display: inline-block;
        text-align: center;
        padding: 13px 18px;
        border-radius: 12px;
        font-weight: 700;
        text-decoration: none;
        transition: 0.3s ease;
    }

    .btn-request {
        background: #16a34a;
        color: white;
    }

    .btn-request:hover {
        background: #15803d;
        color: white;
        transform: translateY(-2px);
    }

    .btn-back {
        background: white;
        color: #2563eb;
        border: 1px solid #2563eb;
    }

    .btn-back:hover {
        background: #2563eb;
        color: white;
    }

    .btn-edit {
        background: #f59e0b;
        color: white;
    }

    .btn-edit:hover {
        background: #d97706;
        color: white;
    }

    @@media (max-width: 900px) {
        .details-layout {
            grid-template-columns: 1fr;
        }

        .details-side-card {
            position: static;
        }
    }

    @@media (max-width: 600px) {
        .details-hero h1 {
            font-size: 34px;
        }

        .details-hero p {
            font-size: 16px;
        }

        .details-main-card,
        .details-side-card {
            padding: 24px;
        }

        .info-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
