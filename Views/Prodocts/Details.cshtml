@model foto4.Data.Prodoct

@{
    ViewData["Title"] = "Детайли за фото продукт";

    var categoryName = Model.Category != null ? Model.Category.Name : "Без категория";
    var description = string.IsNullOrWhiteSpace(Model.Description)
        ? "Няма добавено подробно описание за този фото продукт."
        : Model.Description;
    var createdAt = Model.CreateAt == default
        ? "Не е посочена"
        : Model.CreateAt.ToString("dd.MM.yyyy");

    
    var productImageUrl = Url.Content($"~/images/products/{Model.Id}.png");
    var fallbackImageUrl = Url.Content("~/images/products/default-product.png");
}

<section class="product-details-hero">
    <div class="container">
        <a asp-controller="Prodocts" asp-action="Index" class="back-link">← Обратно към фото продуктите</a>

        <div class="details-hero-grid">
            <div class="product-visual-card">
                <img src="@productImageUrl"
                     alt="@Model.Name"
                     class="product-image"
                     onerror="this.onerror=null;this.src='@fallbackImageUrl';" />
               @*  <span class="visual-label">Фото продукт #@Model.Id</span> *@
            </div>

            <div class="product-main-info">
                <span class="category-badge">@categoryName</span>
                <h1>@Model.Name</h1>
                <p>@description</p>

                <div class="price-box">
                    <span>Цена</span>
                    <strong>@Model.Price.ToString("0.00") лв.</strong>
                </div>

                <div class="details-actions">
                    @if (Model.Id > 0)
                    {
                        <a asp-controller="Prodocts"
                           asp-action="SubmitRequest"
                           asp-route-id="@Model.Id"
                           class="btn-request">
                            Подай заявка
                        </a>
                    }

                    <a asp-controller="Prodocts" asp-action="Index" class="btn-secondary">
                        Всички продукти
                    </a>

                    @if (User.IsInRole("Admin") && Model.Id > 0)
                    {
                        <a asp-controller="Prodocts" asp-action="Edit" asp-route-id="@Model.Id" class="btn-admin">
                            Редактирай
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<section class="product-details-section">
    <div class="container">
        <div class="details-content-grid">
            <div class="info-card large-card">
                <h2>Описание</h2>
                <p>@description</p>
            </div>

            <div class="info-card">
                <div class="info-icon">🏷️</div>
                <h3>Категория</h3>
                <p>@categoryName</p>
            </div>

            <div class="info-card">
                <div class="info-icon">💰</div>
                <h3>Цена</h3>
                <p>@Model.Price.ToString("0.00") лв.</p>
            </div>

            <div class="info-card">
                <div class="info-icon">📅</div>
                <h3>Добавен</h3>
                <p>@createdAt</p>
            </div>
        </div>

        <div class="order-panel">
            <div>
                <h2>Как да направите заявка?</h2>
                <p>
                    Натиснете бутона „Подай заявка“, изберете нужните параметри и опишете как искате да бъде изработен продуктът.
                </p>
            </div>

            @if (Model.Id > 0)
            {
                <a asp-controller="Prodocts"
                   asp-action="SubmitRequest"
                   asp-route-id="@Model.Id"
                   class="btn-request panel-btn">
                    Заяви този продукт
                </a>
            }
        </div>
    </div>
</section>

<style>
    .product-details-hero {
        background: linear-gradient(135deg, #111827, #374151);
        color: white;
        padding: 50px 20px 70px;
        border-radius: 0 0 35px 35px;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .back-link {
        display: inline-block;
        color: #e5e7eb;
        text-decoration: none;
        font-weight: 700;
        margin-bottom: 28px;
        transition: 0.3s;
    }

        .back-link:hover {
            color: white;
            transform: translateX(-4px);
        }

    .details-hero-grid {
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 38px;
        align-items: center;
    }

    .product-visual-card {
        min-height: 330px;
        border-radius: 28px;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.25);
        box-shadow: 0 25px 60px rgba(0, 0, 0, 0.25);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

        .product-visual-card::before {
            content: "";
            width: 220px;
            height: 220px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.12);
            position: absolute;
            top: -60px;
            right: -60px;
        }

    .product-image {
        width: 100%;
        height: 100%;
        min-height: 330px;
        object-fit: cover;
        display: block;
        position: absolute;
        inset: 0;
        z-index: 0;
    }

    .product-visual-card::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(17, 24, 39, 0.05), rgba(17, 24, 39, 0.55));
        z-index: 1;
    }

    .visual-label {
        position: absolute;
        z-index: 2;
        left: 18px;
        bottom: 18px;
        background: rgba(255, 255, 255, 0.88);
        padding: 9px 15px;
        border-radius: 999px;
        font-weight: 800;
        color: #111827;
        backdrop-filter: blur(10px);
    }

    .product-main-info h1 {
        font-size: 46px;
        margin: 15px 0;
        line-height: 1.1;
        font-weight: 800;
    }

    .product-main-info p {
        color: #e5e7eb;
        font-size: 18px;
        line-height: 1.7;
        max-width: 720px;
    }

    .category-badge {
        display: inline-block;
        background: #dbeafe;
        color: #1d4ed8;
        padding: 8px 14px;
        border-radius: 999px;
        font-weight: 800;
        font-size: 14px;
    }

    .price-box {
        display: inline-flex;
        flex-direction: column;
        gap: 4px;
        background: white;
        color: #111827;
        padding: 18px 24px;
        border-radius: 20px;
        margin-top: 22px;
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.18);
    }

        .price-box span {
            color: #6b7280;
            font-weight: 700;
            font-size: 14px;
        }

        .price-box strong {
            color: #16a34a;
            font-size: 30px;
            line-height: 1;
        }

    .details-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 28px;
    }

    .btn-request,
    .btn-secondary,
    .btn-admin {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        border-radius: 14px;
        padding: 12px 18px;
        font-weight: 800;
        transition: 0.3s;
    }

    .btn-request {
        background: #2563eb;
        color: white;
    }

        .btn-request:hover {
            background: #1d4ed8;
            color: white;
            transform: translateY(-2px);
        }

    .btn-secondary {
        background: white;
        color: #111827;
    }

        .btn-secondary:hover {
            background: #f3f4f6;
            color: #111827;
            transform: translateY(-2px);
        }

    .btn-admin {
        background: #f59e0b;
        color: white;
    }

        .btn-admin:hover {
            background: #d97706;
            color: white;
            transform: translateY(-2px);
        }

    .product-details-section {
        padding: 60px 20px;
        background: #f9fafb;
    }

    .details-content-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
        margin-bottom: 30px;
    }

    .info-card {
        background: white;
        border-radius: 22px;
        padding: 26px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        border: 1px solid #eef2f7;
    }

    .large-card {
        grid-column: span 3;
    }

    .info-card h2,
    .order-panel h2 {
        color: #111827;
        font-size: 28px;
        margin-bottom: 12px;
    }

    .info-card h3 {
        color: #111827;
        font-size: 20px;
        margin-bottom: 8px;
    }

    .info-card p,
    .order-panel p {
        color: #4b5563;
        line-height: 1.7;
        margin: 0;
    }

    .info-icon {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        background: #eff6ff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        margin-bottom: 14px;
    }

    .order-panel {
        background: linear-gradient(135deg, #ffffff, #eff6ff);
        border: 1px solid #dbeafe;
        border-radius: 24px;
        padding: 30px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        box-shadow: 0 12px 35px rgba(0, 0, 0, 0.08);
    }

    .panel-btn {
        flex-shrink: 0;
    }

    media (max-width: 900px) {
        .details-hero-grid

    {
        grid-template-columns: 1fr;
    }

    .product-main-info h1 {
        font-size: 36px;
    }

    .details-content-grid {
        grid-template-columns: 1fr;
    }

    .large-card {
        grid-column: span 1;
    }

    .order-panel {
        flex-direction: column;
        align-items: flex-start;
    }

    }

    media (max-width: 520px) {
        .product-details-hero

    {
        padding: 35px 16px 55px;
    }

    .product-details-section {
        padding: 40px 16px;
    }

    .product-main-info h1 {
        font-size: 30px;
    }

    .product-main-info p {
        font-size: 16px;
    }

    .product-visual-card {
        min-height: 240px;
    }

    .product-image {
        min-height: 240px;
    }

    .details-actions,
    .btn-request,
    .btn-secondary,
    .btn-admin,
    .panel-btn {
        width: 100%;
    }

    }</style>
